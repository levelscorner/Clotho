MODE=all
PORT=8080
DATABASE_URL=postgres://clotho:clotho@localhost:5432/clotho?sslmode=disable
OPENAI_API_KEY=sk-your-key-here
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_URL=http://localhost:11434
LOG_LEVEL=info

# JWT authentication (leave empty for dev mode with auto-generated secret)
JWT_SECRET=
JWT_EXPIRY=15m

# Envelope encryption master key (hex-encoded 32 bytes)
# Generate with: openssl rand -hex 32
# Leave empty for dev mode (credentials stored without encryption)
CLOTHO_MASTER_KEY=
